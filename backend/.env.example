# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True
RELOAD=True

# Model Configuration
# Default model for transcription (faster and reliable)
DEFAULT_MODEL=openai/whisper-base

# Pre-load these models on startup (comma-separated)
# Options: whisper-base, whisper-small, whisper-medium, whisper-large-v3
PRELOAD_MODELS=openai/whisper-base,openai/whisper-small,openai/whisper-medium

MAX_AUDIO_SIZE_MB=25
ALLOWED_AUDIO_FORMATS=.wav,.mp3,.flac,.m4a,.ogg

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:5500

# Logging
LOG_LEVEL=INFO

# HuggingFace Configuration
# REQUIRED for speaker diarization (pyannote/speaker-diarization-3.1)
# Get your token at: https://huggingface.co/settings/tokens
# Accept the license at: https://huggingface.co/pyannote/speaker-diarization-3.1
HUGGINGFACE_TOKEN=your_token_here
