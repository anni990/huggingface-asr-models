<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Audio Transcription - HuggingFace Models</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .file-drop-area {
            transition: all 0.3s ease;
        }
        .file-drop-area.drag-over {
            border-color: #3b82f6;
            background-color: #dbeafe;
        }
        .spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #3b82f6;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .fade-in {
            animation: fadeIn 0.5s ease-in;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .tab-button.active {
            border-bottom: 3px solid #3b82f6;
            color: #3b82f6;
        }
    </style>
</head>
<body class="bg-gradient-to-br from-blue-50 to-indigo-100 min-h-screen">
    <!-- Header -->
    <header class="bg-white shadow-md">
        <div class="container mx-auto px-4 py-6">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <i class="fas fa-microphone text-3xl text-blue-600"></i>
                    <h1 class="text-2xl font-bold text-gray-800">Audio Transcription API</h1>
                </div>
                <div class="flex items-center space-x-4">
                    <span id="status-badge" class="px-3 py-1 rounded-full text-sm font-semibold bg-gray-200 text-gray-700">
                        <i class="fas fa-circle text-xs mr-1"></i> Checking...
                    </span>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-8">
        <div class="max-w-6xl mx-auto">
            <!-- Tabs -->
            <div class="bg-white rounded-lg shadow-lg mb-6">
                <div class="flex border-b">
                    <button class="tab-button active px-6 py-3 font-semibold transition" data-tab="transcribe">
                        <i class="fas fa-file-audio mr-2"></i>Transcribe
                    </button>
                    <button class="tab-button px-6 py-3 font-semibold transition text-gray-600" data-tab="models">
                        <i class="fas fa-database mr-2"></i>Model Management
                    </button>
                </div>
            </div>

            <!-- Transcribe Tab -->
            <div id="transcribe-tab" class="tab-content">
                <!-- Info Card -->
            <div class="bg-white rounded-lg shadow-lg p-6 mb-6">
                <h2 class="text-xl font-semibold text-gray-800 mb-3">
                    <i class="fas fa-info-circle text-blue-600 mr-2"></i>About
                </h2>
                <p class="text-gray-600 mb-4">
                    Convert your audio files to text using state-of-the-art HuggingFace AI models. 
                    Upload an audio file in supported formats and get accurate transcriptions in seconds.
                </p>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
                    <div class="bg-blue-50 p-3 rounded-lg">
                        <div class="font-semibold text-blue-900 mb-1">Supported Formats</div>
                        <div class="text-blue-700">.wav, .mp3, .flac, .m4a, .ogg</div>
                    </div>
                    <div class="bg-green-50 p-3 rounded-lg">
                        <div class="font-semibold text-green-900 mb-1">Max File Size</div>
                        <div class="text-green-700">25 MB</div>
                    </div>
                    <div class="bg-purple-50 p-3 rounded-lg">
                        <div class="font-semibold text-purple-900 mb-1">Loaded Models</div>
                        <div id="loaded-models-count" class="text-purple-700">Loading...</div>
                    </div>
                </div>
            </div>

            <!-- Upload Card -->
            <div class="bg-white rounded-lg shadow-lg p-6 mb-6">
                <h2 class="text-xl font-semibold text-gray-800 mb-4">
                    <i class="fas fa-upload text-blue-600 mr-2"></i>Upload Audio File
                </h2>
                
                <!-- Model Selection -->
                <div class="mb-4">
                    <label for="model-select" class="block text-sm font-medium text-gray-700 mb-2">
                        Select Model <span class="text-red-500">*</span>
                    </label>
                    <select 
                        id="model-select" 
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                    >
                        <option value="">Loading models...</option>
                    </select>
                    <p class="mt-1 text-xs text-gray-500">Select a loaded model for transcription</p>
                </div>

                <!-- File Drop Area -->
                <div id="drop-area" class="file-drop-area border-2 border-dashed border-gray-300 rounded-lg p-8 text-center cursor-pointer hover:border-blue-400 hover:bg-blue-50">
                    <div id="upload-prompt">
                        <i class="fas fa-cloud-upload-alt text-5xl text-gray-400 mb-4"></i>
                        <p class="text-lg font-medium text-gray-700 mb-2">Drop your audio file here</p>
                        <p class="text-sm text-gray-500 mb-4">or click to browse</p>
                        <button type="button" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
                            Select File
                        </button>
                    </div>
                    <div id="file-info" class="hidden">
                        <i class="fas fa-file-audio text-5xl text-blue-600 mb-4"></i>
                        <p id="file-name" class="text-lg font-medium text-gray-700 mb-2"></p>
                        <p id="file-size" class="text-sm text-gray-500 mb-4"></p>
                        <button type="button" id="change-file-btn" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition mr-2">
                            Change File
                        </button>
                        <button type="button" id="transcribe-btn" class="px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition">
                            <i class="fas fa-play mr-2"></i>Transcribe
                        </button>
                    </div>
                </div>
                <input type="file" id="file-input" accept=".wav,.mp3,.flac,.m4a,.ogg" class="hidden">
            </div>

            <!-- Loading State -->
            <div id="loading-card" class="hidden bg-white rounded-lg shadow-lg p-6 mb-6">
                <div class="flex items-center justify-center space-x-4">
                    <div class="spinner"></div>
                    <div>
                        <p class="text-lg font-medium text-gray-700">Transcribing audio...</p>
                        <p class="text-sm text-gray-500">This may take a few moments</p>
                    </div>
                </div>
            </div>

            <!-- Results Card -->
            <div id="results-card" class="hidden bg-white rounded-lg shadow-lg p-6 fade-in">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-xl font-semibold text-gray-800">
                        <i class="fas fa-file-alt text-green-600 mr-2"></i>Transcription Result
                    </h2>
                    <button id="copy-btn" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition text-sm">
                        <i class="fas fa-copy mr-2"></i>Copy
                    </button>
                </div>
                
                <div id="transcription-text" class="bg-gray-50 p-4 rounded-lg mb-4 text-gray-800 whitespace-pre-wrap min-h-[100px]"></div>
                
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
                    <div class="bg-blue-50 p-3 rounded-lg">
                        <div class="text-blue-600 font-semibold mb-1">Model Used</div>
                        <div id="result-model" class="text-gray-700 text-xs break-words"></div>
                    </div>
                    <div class="bg-green-50 p-3 rounded-lg">
                        <div class="text-green-600 font-semibold mb-1">Duration</div>
                        <div id="result-duration" class="text-gray-700"></div>
                    </div>
                    <div class="bg-purple-50 p-3 rounded-lg">
                        <div class="text-purple-600 font-semibold mb-1">Processing Time</div>
                        <div id="result-time" class="text-gray-700"></div>
                    </div>
                    <div class="bg-orange-50 p-3 rounded-lg">
                        <div class="text-orange-600 font-semibold mb-1">Characters</div>
                        <div id="result-chars" class="text-gray-700"></div>
                    </div>
                </div>
            </div>
            </div>

            <!-- Models Tab -->
            <div id="models-tab" class="tab-content hidden">
                <!-- Load Model Card -->
                <div class="bg-white rounded-lg shadow-lg p-6 mb-6">
                    <h2 class="text-xl font-semibold text-gray-800 mb-4">
                        <i class="fas fa-plus-circle text-green-600 mr-2"></i>Load New Model
                    </h2>
                    
                    <div class="flex gap-4">
                        <input 
                            type="text" 
                            id="new-model-id" 
                            placeholder="e.g., openai/whisper-large-v3"
                            class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                        >
                        <button 
                            id="load-model-btn"
                            class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
                            <i class="fas fa-download mr-2"></i>Load Model
                        </button>
                    </div>
                    
                    <div class="mt-4">
                        <p class="text-sm font-medium text-gray-700 mb-2">Recommended Models:</p>
                        <div id="recommended-models" class="flex flex-wrap gap-2">
                            <!-- Will be populated by JS -->
                        </div>
                    </div>
                </div>

                <!-- Models List Card -->
                <div class="bg-white rounded-lg shadow-lg p-6">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-xl font-semibold text-gray-800">
                            <i class="fas fa-list text-blue-600 mr-2"></i>Registered Models
                        </h2>
                        <button id="refresh-models-btn" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition text-sm">
                            <i class="fas fa-sync-alt mr-2"></i>Refresh
                        </button>
                    </div>
                    
                    <div id="models-list" class="space-y-3">
                        <!-- Will be populated by JS -->
                        <div class="text-center text-gray-500 py-8">
                            <i class="fas fa-spinner fa-spin text-3xl mb-3"></i>
                            <p>Loading models...</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Error Card -->
            <div id="error-card" class="hidden bg-red-50 border border-red-200 rounded-lg p-6 fade-in">
                <div class="flex items-start">
                    <i class="fas fa-exclamation-circle text-2xl text-red-600 mr-3 mt-1"></i>
                    <div class="flex-1">
                        <h3 class="text-lg font-semibold text-red-800 mb-2">Error</h3>
                        <p id="error-message" class="text-red-700"></p>
                    </div>
                    <button id="close-error-btn" class="text-red-600 hover:text-red-800">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-white mt-12 py-6">
        <div class="container mx-auto px-4 text-center text-gray-600 text-sm">
            <p>Powered by HuggingFace Transformers & FastAPI</p>
            <p class="mt-2">
                <a href="http://localhost:8000/docs" target="_blank" class="text-blue-600 hover:text-blue-800">
                    <i class="fas fa-book mr-1"></i>API Documentation
                </a>
            </p>
        </div>
    </footer>

    <script src="app.js"></script>
</body>
</html>
